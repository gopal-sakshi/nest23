{
    "name": "nest23",
    "version": "0.0.1",
    "description": "",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "nest start",
        "prestart:dev": "rimraf dist *.tsbuildinfo",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "@apollo/server": "^5.2.0",
        "@as-integrations/express5": "^1.1.2",
        "@aws-sdk/client-dynamodb": "^3.1068.0",
        "@aws-sdk/client-s3": "^3.1068.0",
        "@aws-sdk/client-sts": "^3.1068.0",
        "@aws-sdk/credential-providers": "^3.1068.0",
        "@aws-sdk/util-dynamodb": "^3.996.4",
        "@grpc/grpc-js": "^1.14.3",
        "@grpc/proto-loader": "^0.8.0",
        "@nestjs/apollo": "^13.2.1",
        "@nestjs/bullmq": "^11.0.4",
        "@nestjs/common": "^11.0.1",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.0.1",
        "@nestjs/graphql": "^13.2.0",
        "@nestjs/mapped-types": "^2.1.0",
        "@nestjs/microservices": "^11.1.19",
        "@nestjs/mongoose": "^11.0.3",
        "@nestjs/platform-express": "^11.0.1",
        "@nestjs/platform-socket.io": "^11.1.26",
        "@nestjs/schedule": "^6.1.3",
        "@nestjs/websockets": "^11.1.26",
        "@opentelemetry/api": "^1.9.1",
        "@opentelemetry/auto-instrumentations-node": "^0.76.0",
        "@opentelemetry/exporter-trace-otlp-proto": "^0.218.0",
        "@opentelemetry/sdk-node": "^0.218.0",
        "@opentelemetry/sdk-trace-node": "^2.7.1",
        "class-validator": "^0.14.2",
        "graphql": "^16.12.0",
        "graphql-request": "^7.4.0",
        "graphql-subscriptions": "^3.0.0",
        "handlebars": "^4.7.9",
        "kafkajs": "^2.2.4",
        "nest-winston": "^1.10.2",
        "prom-client": "^15.1.3",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "ts-morph": "^25.0.1",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.2.0",
        "@eslint/js": "^9.18.0",
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.1",
        "@types/express": "^5.0.3",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.10.7",
        "@types/supertest": "^6.0.2",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-prettier": "^5.2.2",
        "globals": "^16.0.0",
        "jest": "^30.0.0",
        "prettier": "^3.4.2",
        "rimraf": "^6.1.3",
        "source-map-support": "^0.5.21",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.20.0"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
